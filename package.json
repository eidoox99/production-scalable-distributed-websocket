{
  "name": "realtime-production-socketio",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @pkg/shared build && pnpm --filter @app/auth-service build && pnpm --filter @app/ws-gateway build && pnpm --filter @app/api-gateway build && pnpm --filter @app/client build",
    "build:shared": "pnpm --filter @pkg/shared build",
    "build:auth-service": "pnpm --filter @app/auth-service build",
    "build:ws-gateway": "pnpm --filter @app/ws-gateway build",
    "build:api-gateway": "pnpm --filter @app/api-gateway build",
    "build:client": "pnpm --filter @app/client build",
    "start:auth-service": "pnpm --filter @app/auth-service start",
    "start:ws-gateway": "pnpm --filter @app/ws-gateway start",
    "start:api-gateway": "pnpm --filter @app/api-gateway start",
    "start:client": "pnpm --filter @app/client start"
  },
  "packageManager": "pnpm@9.15.0"
}
